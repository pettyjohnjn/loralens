#!/bin/bash
#PBS -N loralens_gpt2_mc_expanded
#PBS -l select=1:ncpus=32:ngpus=4
#PBS -l walltime=01:00:00
#PBS -q debug
#PBS -l filesystems=home:grand:eagle
#PBS -A ModCon

REPO=/lus/eagle/projects/ModCon/jpettyjohn/loralens-refactored
CKPT_BASE=$REPO/src/checkpoints

# ── Node topology ─────────────────────────────────────────────────────────────
MASTER_ADDR=$(head -1 $PBS_NODEFILE)
NNODES=$(sort -u $PBS_NODEFILE | wc -l)
NGPUS_PER_NODE=4
MASTER_PORT=29500

echo "Nodes: $NNODES  |  GPUs/node: $NGPUS_PER_NODE  |  Master: $MASTER_ADDR:$MASTER_PORT"

# ── Environment ───────────────────────────────────────────────────────────────
module use /soft/modulefiles
module load conda
conda activate LoRA_Lens
source ~/.hf_env
export PYTHONPATH=$REPO/src:$PYTHONPATH
export TOKENIZERS_PARALLELISM=false
export OMP_NUM_THREADS=8

# ── Launch ────────────────────────────────────────────────────────────────────
python -m torch.distributed.run \
    --nnodes=1 --nproc_per_node=$NGPUS_PER_NODE --standalone \
    -m loralens.cli.main train \
    --model_name gpt2 \
    --lens_type lora \
    --lora_rank 64 \
    --lora_init default_lora \
    --loss_type subset_kl \
    --subset_kl_mode mc \
    --subset_kl_k 512 \
    --subset_kl_k_tail 1024 \
    --activation_site_preset gpt2_expanded \
    --data_source pile \
    --max_seq_len 1024 \
    --batch_size 4 \
    --tokens_per_step 262144 \
    --num_steps 50 \
    --lr 1e-3 \
    --amp \
    --amp_dtype bf16 \
    --save_every 25 \
    --log_every 5 \
    --base_output_dir $CKPT_BASE

echo "Done."
