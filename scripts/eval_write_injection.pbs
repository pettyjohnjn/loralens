#!/bin/bash
#PBS -N eval_write_injection
#PBS -l select=1:ncpus=32:ngpus=4
#PBS -l walltime=01:00:00
#PBS -q debug
#PBS -l filesystems=home:grand:eagle
#PBS -A ModCon
#PBS -j oe

set -euo pipefail

REPO=/lus/eagle/projects/ModCon/jpettyjohn/loralens-refactored
CKPT_BASE=$REPO/src/checkpoints
OUT_DIR=/lus/eagle/projects/ModCon/jpettyjohn/evaluation/write_injection

module use /soft/modulefiles
module load conda
conda activate LoRA_Lens
source ~/.hf_env
export PYTHONPATH=$REPO/src:$PYTHONPATH
export TOKENIZERS_PARALLELISM=false
export OMP_NUM_THREADS=8

ORTHO_CKPT="${CKPT_BASE}/gpt2/bidir-r64-ortho/subset_kl-mc-k512-tail1024/gpt2_expanded/init-default/seed0/lens_step_250.pt"
SUFFIX_CKPT="${CKPT_BASE}/gpt2/bidir-r64-suffix/subset_kl-mc-k512-tail1024/gpt2_expanded/init-ridge/seed0/lens_step_500.pt"
OUT_FILE="${OUT_DIR}/write_injection_eval.json"

mkdir -p "${OUT_DIR}"

echo "[eval] Running write injection evaluation"
echo "  ortho  : ${ORTHO_CKPT}"
echo "  suffix : ${SUFFIX_CKPT}"
echo "  output : ${OUT_FILE}"

# Single GPU is sufficient — this is inference-only
CUDA_VISIBLE_DEVICES=0 python "${REPO}/scripts/eval_write_injection.py" \
    --ortho_ckpt  "${ORTHO_CKPT}"  \
    --suffix_ckpt "${SUFFIX_CKPT}" \
    --out         "${OUT_FILE}"    \
    --n_examples  512              \
    --model_name  gpt2             \
    --device      cuda

echo "[done] results at ${OUT_FILE}"
